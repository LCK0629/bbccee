  <diagram name="第 1 页" id="raEUEC3axG1P0WpqPgoy">
    <mxGraphModel dx="1201" dy="730" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="QZNlm_UlfSd-8NdxVIhh-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;- As a user, I want to create a booking so that I can reserve a car.&lt;/div&gt;&lt;div&gt;- As a user, I want to view a booking so that I can check the booking details.&lt;/div&gt;&lt;div&gt;- As a user, I want to update a booking so that I can modify booking information.&lt;/div&gt;&lt;div&gt;- As a user, I want to cancel a booking so that I can remove a reservation.&lt;/div&gt;&lt;div&gt;- As a user, I want to search bookings so that I can find booking records quickly.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="530" x="170" y="130" as="geometry" />
        </mxCell>
        <mxCell id="QZNlm_UlfSd-8NdxVIhh-3" edge="1" parent="1" source="QZNlm_UlfSd-8NdxVIhh-2" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.75;exitY=1;exitDx=0;exitDy=0;fontSize=12;startSize=8;endSize=8;" target="QZNlm_UlfSd-8NdxVIhh-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="QZNlm_UlfSd-8NdxVIhh-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Create:&#xa;- Create booking&#xa;&#xa;&#xa;Read:&#xa;- View booking details&#xa;&#xa;&#xa;Update:&#xa;- Update booking&#xa;&#xa;&#xa;Delete:&#xa;- Cancel booking&#xa;&#xa;&#xa;Search:&#xa;- Search available cars&#xa;- Search booking by ID" vertex="1">
          <mxGeometry height="270" width="450" x="170" y="300" as="geometry" />
        </mxCell>
        <mxCell id="QZNlm_UlfSd-8NdxVIhh-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;| Field&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; | Description |&lt;/div&gt;&lt;div&gt;|------------------|------------|&lt;/div&gt;&lt;div&gt;| Use Case ID&amp;nbsp; &amp;nbsp; &amp;nbsp; | CB-01 |&lt;/div&gt;&lt;div&gt;| Use Case Name&amp;nbsp; &amp;nbsp; | Create Booking |&lt;/div&gt;&lt;div&gt;| Description&amp;nbsp; &amp;nbsp; &amp;nbsp; | This use case allows the user to create a car booking. |&lt;/div&gt;&lt;div&gt;| Actor&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; | User |&lt;/div&gt;&lt;div&gt;| Trigger&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; | User clicks &quot;Book Car&quot;. |&lt;/div&gt;&lt;div&gt;| Precondition&amp;nbsp; &amp;nbsp; &amp;nbsp;| 1. User is logged in. &amp;lt;br&amp;gt;2. Booking system is available. |&lt;/div&gt;&lt;div&gt;| Postcondition&amp;nbsp; &amp;nbsp; | A booking record is created successfully. |&lt;/div&gt;&lt;div&gt;| Main Flow&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; | 1. User enters booking details. &amp;lt;br&amp;gt;2. System validates input. &amp;lt;br&amp;gt;3. System creates booking. &amp;lt;br&amp;gt;4. System displays confirmation. |&lt;/div&gt;&lt;div&gt;| Alternative Flow | A1: Invalid input &amp;lt;br&amp;gt;1. System displays error message. |&lt;/div&gt;" vertex="1">
          <mxGeometry height="390" width="590" x="190" y="660" as="geometry" />
        </mxCell>
        <UserObject label="&lt;img src=&quot;https://uml.planttext.com/plantuml/png/TLBBQiCm4BmR_0_2f_JXq5vBCA5n3pa42cq_O6qlHbIHocfT2AN_thNik0fsJh9cHZEhaRUUWRWxcZH9azg0z-hPkKzjsrTeKMqsbUji0tGg2lMJ9ahTDTf_6JYDgX8PjF6hcvXx8N9qGE_5ecT-P-OxPvcSCKWIKG-RAQ4c1CPHkUeyqhwyLpM4fH7gNHzn26oHpxfgMFVbOg34e6NDqptoIQ-UbBOSiBEvGENu6N0fYJilw1kJdBa8s07DpSEmaR7i3wv14ra82j_I7LJQoD5bym-F2-v39P5z3rW8Sr-On4-PvyMy_KaIFKWal4RBdQzH_SHzT9WyUym2c3sirxVPlslVsJKkJRPe6_aZ_m00&quot; alt=&quot;PlantUML Diagram&quot;&gt;" link="&lt;img src=&quot;https://uml.planttext.com/plantuml/png/TLBBQiCm4BmR_0_2f_JXq5vBCA5n3pa42cq_O6qlHbIHocfT2AN_thNik0fsJh9cHZEhaRUUWRWxcZH9azg0z-hPkKzjsrTeKMqsbUji0tGg2lMJ9ahTDTf_6JYDgX8PjF6hcvXx8N9qGE_5ecT-P-OxPvcSCKWIKG-RAQ4c1CPHkUeyqhwyLpM4fH7gNHzn26oHpxfgMFVbOg34e6NDqptoIQ-UbBOSiBEvGENu6N0fYJilw1kJdBa8s07DpSEmaR7i3wv14ra82j_I7LJQoD5bym-F2-v39P5z3rW8Sr-On4-PvyMy_KaIFKWal4RBdQzH_SHzT9WyUym2c3sirxVPlslVsJKkJRPe6_aZ_m00&quot; alt=&quot;PlantUML Diagram&quot;&gt;" id="QZNlm_UlfSd-8NdxVIhh-6">
